# AI 服务提供商配置
# 支持同时配置多个 AI 服务，系统会自动检测已配置的服务

# ============ Google Gemini ============
# 获取地址: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# 可选: 指定模型版本 (默认: gemini-2.0-flash)
# VITE_GEMINI_MODEL=gemini-2.0-flash
# 可选: 指定自定义 API 地址
# VITE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models

# ============ OpenAI GPT ============
# 获取地址: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here
# 可选: 指定模型版本 (默认: gpt-3.5-turbo)
# VITE_OPENAI_MODEL=gpt-3.5-turbo
# 可选: 指定自定义 API 地址 (用于代理或兼容服务)
# VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# ============ AI 服务选择 ============
# 可选: 指定默认使用的 AI 服务 (gemini | openai)
# 如果不指定，系统会自动选择第一个配置好的服务
# VITE_DEFAULT_AI_PROVIDER=gemini
